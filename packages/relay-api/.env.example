# AWS Configuration
AWS_REGION=us-east-1

# DynamoDB Tables (populated by CloudFormation outputs after Phase 2 deploy)
EVENTS_TABLE=relay-events
EXECUTIONS_TABLE=relay-executions
WORKFLOWS_TABLE=relay-workflows
PROJECTS_TABLE=relay-projects
AUDIT_TABLE=relay-audit

# SQS Queues
MAIN_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/{account-id}/relay-main-queue
DLQ_URL=https://sqs.us-east-1.amazonaws.com/{account-id}/relay-dlq

# S3 Buckets
PAYLOAD_BUCKET=relay-payloads-{account-id}
ARTIFACTS_BUCKET=relay-artifacts-{account-id}
SNAPSHOTS_BUCKET=relay-snapshots-{account-id}
